# Embedding model (HuggingFace)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Reranker model
RERANK_MODEL=BAAI/bge-reranker-base

# LLM configuration
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# Chunking settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Retrieval settings
RETRIEVAL_TOP_K=10
RERANK_TOP_N=5

# Whisper model
WHISPER_MODEL=base